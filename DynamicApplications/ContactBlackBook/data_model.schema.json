{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contacts.addressbook.schema.v1",
  "title": "Contacts Address Book Schema",
  "type": "object",
  "required": ["store", "contacts"],
  "properties": {
    "store": {
      "type": "object",
      "required": ["version", "ownerScope", "updatedAt", "etag"],
      "properties": {
        "version": { "type": "string", "const": "1.0.0" },
        "ownerScope": { "type": "string", "enum": ["per_user", "shared"] },
        "updatedAt": { "type": "string", "format": "date-time" },
        "etag": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "contacts": {
      "type": "array",
      "items": { "$ref": "#/$defs/contact" }
    }
  },
  "$defs": {
    "contact": {
      "type": "object",
      "required": ["contactId", "displayName", "phones", "addresses", "createdAt", "updatedAt"],
      "properties": {
        "contactId": { "type": "string", "minLength": 8, "maxLength": 64 },
        "displayName": { "type": "string", "minLength": 1, "maxLength": 200 },
        "givenName": { "type": "string", "maxLength": 100 },
        "familyName": { "type": "string", "maxLength": 100 },
        "emails": {
          "type": "array",
          "items": { "type": "string", "format": "email" },
          "maxItems": 10
        },
        "phones": {
          "type": "array",
          "minItems": 1,
          "maxItems": 10,
          "items": {
            "type": "object",
            "required": ["label", "number"],
            "properties": {
              "label": { "type": "string", "enum": ["mobile", "home", "work", "other"] },
              "number": { "type": "string", "minLength": 3, "maxLength": 40 }
            },
            "additionalProperties": false
          }
        },
        "addresses": {
          "type": "array",
          "minItems": 1,
          "maxItems": 5,
          "items": {
            "type": "object",
            "required": ["label", "line1", "city", "region", "postalCode", "country"],
            "properties": {
              "label": { "type": "string", "enum": ["home", "work", "other"] },
              "line1": { "type": "string", "minLength": 1, "maxLength": 200 },
              "line2": { "type": "string", "maxLength": 200 },
              "city": { "type": "string", "minLength": 1, "maxLength": 120 },
              "region": { "type": "string", "minLength": 1, "maxLength": 120 },
              "postalCode": { "type": "string", "minLength": 1, "maxLength": 40 },
              "country": { "type": "string", "minLength": 2, "maxLength": 120 }
            },
            "additionalProperties": false
          }
        },
        "tags": { "type": "array", "items": { "type": "string", "maxLength": 40 }, "maxItems": 20 },
        "notes": { "type": "string", "maxLength": 4000 },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "deletedAt": { "type": ["string", "null"], "format": "date-time" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}